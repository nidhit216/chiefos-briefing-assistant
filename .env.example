# Database
POSTGRES_USER=chiefos
POSTGRES_PASSWORD=chiefos_dev_password
POSTGRES_DB=chiefos
DATABASE_URL=postgresql+asyncpg://chiefos:chiefos_dev_password@db:5432/chiefos

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend
SECRET_KEY=change-this-to-a-random-secret-key
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# AI (OpenAI-compatible provider)
# For Groq (FREE): get key at https://console.groq.com
OPENAI_API_KEY=your-groq-or-openai-api-key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-70b-versatile
# For OpenAI: comment out AI_BASE_URL and set AI_MODEL=gpt-4o
# For Ollama (local): AI_BASE_URL=http://host.docker.internal:11434/v1, AI_MODEL=llama3

# Email Delivery (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=briefs@yourdomain.com
